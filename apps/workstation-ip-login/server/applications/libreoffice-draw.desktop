[Desktop Entry]
Version=1.0
Type=Application
Name=LibreOffice Draw
Name[ko]=리브레오피스 Draw
Comment=Launch LibreOffice Draw with the managed Korean locale wrapper
Comment[ko]=관리형 한국어 locale 래퍼로 리브레오피스 Draw 를 실행합니다
Exec=/usr/local/bin/workstation-libreoffice --draw %U
TryExec=/usr/local/bin/workstation-libreoffice
Icon=libreoffice-draw
Terminal=false
StartupNotify=true
Categories=Graphics;Office;
