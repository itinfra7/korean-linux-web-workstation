WORKSTATION_PRODUCT_TITLE=korean-linux-web-workstation
WORKSTATION_PUBLIC_DOMAIN=example.com
WORKSTATION_PUBLIC_BASE_URL=https://example.com
WORKSTATION_MAIL_DOMAIN=example.com

WORKSTATION_IPLOGIN_REDIS_URL=redis://127.0.0.1:6379/3
WORKSTATION_IPLOGIN_MAIL_DOMAIN=example.com
WORKSTATION_IPLOGIN_SENDMAIL_PATH=/usr/sbin/sendmail
WORKSTATION_IPLOGIN_LDAP_HOST=ldap.example.com
WORKSTATION_IPLOGIN_LDAP_PORT=636
WORKSTATION_IPLOGIN_LDAP_BASE_DN=dc=example,dc=com
WORKSTATION_IPLOGIN_LDAP_PEOPLE_DN=ou=people,dc=example,dc=com
WORKSTATION_IPLOGIN_LDAP_CA_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

WORKSTATION_IPLOGIN_EXTERNAL_EMAIL_STORE_FILE=/var/lib/workstation-state/workstation-ip-login/external-email-store.json
WORKSTATION_IPLOGIN_EXTERNAL_EMAIL_VERIFICATION_TTL_SECONDS=600
WORKSTATION_IPLOGIN_GRANT_TTL_SECONDS=180
WORKSTATION_IPLOGIN_SESSION_TTL_SECONDS=28800
WORKSTATION_IPLOGIN_GRANT_RECORD_TTL_SECONDS=86400
WORKSTATION_IPLOGIN_SESSION_COOKIE_NAME=workstation_iplogin_session

WORKSTATION_IPLOGIN_DISCORD_GUILD_ID=000000000000000000
WORKSTATION_IPLOGIN_DISCORD_CHANNEL_ID=000000000000000000
WORKSTATION_IPLOGIN_DISCORD_ROLE_ID=000000000000000000
WORKSTATION_IPLOGIN_DISCORD_TOKEN_FILE=/etc/korean-linux-web-workstation/discord-bot.token

WORKSTATION_IPLOGIN_DESKTOP_HELPER=/usr/local/sbin/workstation-desktop-session
WORKSTATION_IPLOGIN_DESKTOP_BACKEND_HOST=127.0.0.1
WORKSTATION_IPLOGIN_DESKTOP_PROXY_USER=desktop-proxy-user-placeholder
WORKSTATION_IPLOGIN_DESKTOP_PROXY_PASSWORD=desktop-proxy-password-placeholder

WORKSTATION_DESKTOP_USERS_ROOT=/var/lib/workstation-desktop/users
WORKSTATION_IPLOGIN_CHAT_STORE_FILE=/var/lib/workstation-state/workstation-ip-login/chat.sqlite3
WORKSTATION_IPLOGIN_CHAT_MEDIA_ROOT=/var/lib/workstation-state/workstation-ip-login/chat-media

WORKSTATION_MAIL_HOST=mail.example.com
WORKSTATION_LDAP_BASE_DN=dc=example,dc=com
